      <h2 id="appendix">Annexe : Référence Rapide</h2>

      <h3>Emplacements importants des fichiers</h3>
      <table class="guide-table">
        <thead><tr><th>Fichier</th><th>Docker Hub</th><th>Natif</th></tr></thead>
        <tbody>
