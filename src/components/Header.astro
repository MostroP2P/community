---
import { type Locale, t, getLocalePath, getOtherLocales, getLocaleLabel } from '../i18n/translations';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const i = t(locale);
const otherLocales = getOtherLocales(locale);
---
<header class="header">
  <div class="container header-inner">
    <a href={getLocalePath(locale)} class="logo">
      <span class="logo-icon">🧌</span>
      <span class="logo-text">Mostro<span class="logo-accent">.community</span></span>
    </a>
    <nav class="nav">
      <a href="#communities">{i.nav.communities}</a>
      <a href="#how-it-works">{i.nav.howItWorks}</a>
      <a href="#start">{i.nav.getStarted}</a>
      <a href="#faq">{i.nav.faqNav}</a>
      <a href={getLocalePath(locale, '/guide')}>{i.nav.guideNav}</a>
      <a href={getLocalePath(locale, '/call-for-action')}>{i.nav.joinNav}</a>
      <a href="https://mostro.network" target="_blank" class="btn btn-outline btn-sm">{i.nav.protocol}</a>
      <div class="lang-dropdown">
        <button class="lang-switch" id="lang-toggle" aria-expanded="false" aria-haspopup="true" aria-controls="lang-menu">{i.langSwitch} {getLocaleLabel(locale).split(' ')[0]}</button>
        <div class="lang-menu" id="lang-menu" role="menu">
          {otherLocales.map(l => (
            <a href={getLocalePath(l)} class="lang-option" role="menuitem" data-locale={l}>{getLocaleLabel(l)}</a>
          ))}
        </div>
      </div>
    </nav>
    <div class="mobile-actions">
      <div class="lang-dropdown">
        <button class="lang-switch" id="lang-toggle-mobile" aria-expanded="false" aria-haspopup="true" aria-controls="lang-menu-mobile">{i.langSwitch} {getLocaleLabel(locale).split(' ')[0]}</button>
        <div class="lang-menu" id="lang-menu-mobile" role="menu">
          {otherLocales.map(l => (
            <a href={getLocalePath(l)} class="lang-option" role="menuitem" data-locale={l}>{getLocaleLabel(l)}</a>
          ))}
        </div>
      </div>
      <button class="mobile-menu" aria-label="Menu" id="mobile-menu-btn">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(29, 33, 44, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    min-width: 0; /* Allow flex children to shrink within container */
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    flex-shrink: 0;      /* Prevent logo from being squeezed by flex siblings */
    white-space: nowrap; /* Prevent "Mostro.community" from wrapping or merging */
  }

  .logo:hover { color: var(--text-primary); }

  .logo-icon { font-size: 1.6rem; }
  .logo-accent { color: var(--accent); }

  /* Scale logo down on narrow phones so lang button has room */
  @media (max-width: 480px) {
    .logo {
      font-size: 1.05rem;
      gap: 6px;
    }
    .logo-icon {
      font-size: 1.35rem;
    }
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav a {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav a:hover { color: var(--text-primary); }

  .btn-sm { padding: 8px 18px; font-size: 0.85rem; }

  .lang-dropdown {
    position: relative;
  }

  .lang-switch {
    padding: 6px 14px;
    border-radius: 8px;
    background: rgba(140, 198, 63, 0.08);
    border: 1px solid var(--border);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    transition: all 0.2s;
    cursor: pointer;
  }

  .lang-switch:hover {
    background: rgba(140, 198, 63, 0.15);
    border-color: var(--border-hover);
  }

  .lang-menu {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: rgba(29, 33, 44, 0.95);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px;
    min-width: 100px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 200;
  }

  .lang-menu.open {
    display: flex;
    flex-direction: column;
  }

  .lang-option {
    padding: 8px 14px;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary) !important;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .lang-option:hover {
    background: rgba(140, 198, 63, 0.1);
    color: var(--text-primary) !important;
  }

  .mobile-actions {
    display: none;
    align-items: center;
    gap: 12px;
  }

  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .mobile-menu span {
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: 0.3s;
  }

  /*
   * Tier 1 — Graceful compression (1025px–1200px)
   * The nav has 8 items. This tier tightens spacing to keep all
   * links visible on large tablets / small laptops before collapsing.
   */
  @media (max-width: 1280px) {
    .nav {
      gap: 16px;
    }

    .nav a {
      font-size: 0.875rem;
    }

    .btn-sm {
      padding: 7px 14px;
      font-size: 0.8rem;
    }
  }

  /*
   * Tier 2 — Mobile / tablet collapse (≤1024px)
   * Raised from 768px → 1024px. With 8 nav items the minimum
   * comfortable desktop width is ~1100px. 1024px is the nearest
   * industry-standard breakpoint (Tailwind lg, iPad landscape).
   */
  @media (max-width: 1100px) {
    .nav { display: none; }
    .nav .lang-dropdown { display: none; }
    .mobile-actions { display: flex; }
  }
</style>

<script>
  function setupLangDropdown(toggleId: string, menuId: string) {
    const toggle = document.getElementById(toggleId);
    const menu = document.getElementById(menuId);
    if (!toggle || !menu) return;

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });
  }

  // Fix language links to preserve current page path
  function fixLangLinks() {
    const path = window.location.pathname;
    // Extract current page (e.g. /guide, /call-for-action) from path
    const segments = path.split('/').filter(Boolean);
    // Remove locale prefix if present
    const locales = ['es', 'fr', 'it', 'pt'];
    let pagePath = '/';
    if (segments.length > 0 && locales.includes(segments[0])) {
      pagePath = segments.length > 1 ? '/' + segments.slice(1).join('/') : '/';
    } else {
      pagePath = segments.length > 0 ? '/' + segments.join('/') : '/';
    }

    document.querySelectorAll('.lang-option').forEach((link) => {
      const locale = (link as HTMLElement).dataset.locale;
      if (!locale) return;
      if (locale === 'en') {
        (link as HTMLAnchorElement).href = pagePath;
      } else {
        (link as HTMLAnchorElement).href = `/${locale}${pagePath === '/' ? '' : pagePath}`;
      }
    });
  }

  fixLangLinks();

  setupLangDropdown('lang-toggle', 'lang-menu');
  setupLangDropdown('lang-toggle-mobile', 'lang-menu-mobile');

  document.addEventListener('click', () => {
    document.querySelectorAll('.lang-menu').forEach(m => m.classList.remove('open'));
    document.querySelectorAll('.lang-switch').forEach(b => b.setAttribute('aria-expanded', 'false'));
  });

  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const nav = document.querySelector('.nav') as HTMLElement;
    const btn = document.getElementById('mobile-menu-btn');
    if (!nav) return;

    // Use data attribute for state — nav.style.display is '' on first click
    // because CSS-applied display:none does not set the inline style property
    const isOpen = nav.getAttribute('data-mobile-open') === 'true';

    if (isOpen) {
      nav.removeAttribute('style');
      nav.removeAttribute('data-mobile-open');
      btn?.setAttribute('aria-expanded', 'false');
    } else {
      Object.assign(nav.style, {
        display: 'flex',
        flexDirection: 'column',
        position: 'absolute',
        top: '72px',
        left: '0',
        right: '0',
        background: 'rgba(29, 33, 44, 0.95)',
        padding: '24px',
        borderBottom: '1px solid var(--border)',
      });
      nav.setAttribute('data-mobile-open', 'true');
      btn?.setAttribute('aria-expanded', 'true');
    }
  });
</script>
